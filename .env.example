# DATABASE
DATABASE_URL=postgresql://dev:dev123@localhost:5432/BuscaPrecosWeb

# REDIS
REDIS_URL=redis://localhost:6379

# EXTERNAL APIS
SERPER_API_KEY=your_serper_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here

# CATMAT AI AGENT
# Supabase project URL and service-role key (required for CATMAT matching)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# Name of the CATMAT table in Supabase (default: catmat)
# Expected columns: codigo TEXT, descricao TEXT, unidade TEXT (optional)
CATMAT_TABLE=catmat
# OpenAI API key for AI-powered CATMAT ranking
OPENAI_API_KEY=your_openai_api_key_here

# APP CONFIG
PORT=3001
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
